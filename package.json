{
  "name": "open-recorder",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:release": "node scripts/build-release-bundles.mjs",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "release": "node scripts/release-auto.mjs",
    "release:auto": "node scripts/release-auto.mjs",
    "release:dry": "npm run version:check && node scripts/release-dry-run.mjs",
    "release:patch": "node scripts/release-auto.mjs patch",
    "release:minor": "node scripts/release-auto.mjs minor",
    "release:major": "node scripts/release-auto.mjs major"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "canvg": "^4.0.3",
    "dompurify": "^3.3.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.5",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "release-it": "^19.2.4",
    "typescript": "^5.8.2",
    "vite": "^6.0.0"
  }
}
